bin/
.data/
.ai/
node_modules/

# Ignore daffa binary
daffa

# The compiled SPA is a build artifact, but internal/web/dist itself must survive a fresh
# clone: //go:embed fails on a missing dir, so `go build` would break before `make web` ever
# ran. Vite writes into the dist/app subdir (wiped on every build); the tracked dist/.gitkeep
# sits one level up, out of that path, so a build never deletes it.
internal/web/dist/app/
*.db
*.db-wal
*.db-shm
master.key
.DS_Store
