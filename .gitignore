bin/
.data/
.ai/
node_modules/

# The compiled SPA is a build artifact, but the directory itself must survive a fresh
# clone: //go:embed fails on a missing dir, so `go build` would break before `make web`
# ever ran. The placeholder is tracked; everything Vite emits beside it is not.
internal/web/dist/*
!internal/web/dist/.gitkeep
*.db
*.db-wal
*.db-shm
master.key
.DS_Store
