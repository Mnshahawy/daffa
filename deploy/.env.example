# Daffa deployment configuration.
#
# Copy this to `.env` (next to docker-compose.yml) and fill it in, or let
# ./install.sh write it for you. Everything the compose file reads lives here.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# Keep .env to mode 600: it holds the database password.

# ── Which mode ──────────────────────────────────────────────────────────────
# `traefik` puts Daffa behind a TLS-terminating Traefik proxy (production).
# Leave empty for direct mode: plain http on loopback, no proxy.
COMPOSE_PROFILES=traefik

# ── Traefik mode (COMPOSE_PROFILES=traefik) ─────────────────────────────────
# A DNS name that points at this host. Traefik (traefik.yml) serves both public and
# internal sites per-router; this only decides the CONSOLE's own certificate:
#   • DAFFA_CERTRESOLVER=le  — public domain; Traefik gets a Let's Encrypt cert (needs
#                              ACME_EMAIL, and :443 reachable from the internet).
#   • DAFFA_CERTRESOLVER=    — internal domain; Daffa issues the cert from its own CA and
#                              delivers it into the daffa-edge-certs volume (`daffa edge init`).
DAFFA_DOMAIN=daffa.example.com
DAFFA_CERTRESOLVER=le
# Where Let's Encrypt sends expiry warnings. Required for a public console; optional for an
# internal one, where it just enables ACME for OTHER public sites behind this same Traefik.
ACME_EMAIL=you@example.com

# Behind Traefik, TLS is real: keep Secure cookies on and trust the proxy's
# forwarded client address. In direct mode set BOTH to false.
DAFFA_SECURE_COOKIE=true
DAFFA_TRUST_PROXY=true

# ── Direct mode (COMPOSE_PROFILES empty) ────────────────────────────────────
# Daffa is published on this address/port in plain http. Keep the bind on
# 127.0.0.1 unless you run your own TLS terminator in front — a Secure-cookie-off
# console on a public interface is a credential leak waiting to happen.
DAFFA_BIND=127.0.0.1
DAFFA_PORT=8080
# For direct mode, uncomment these two (and comment out the traefik pair above):
# DAFFA_SECURE_COOKIE=false
# DAFFA_TRUST_PROXY=false

# ── Database ────────────────────────────────────────────────────────────────
# Password for the bundled PostgreSQL. Generate a strong one:
#   openssl rand -base64 24
POSTGRES_PASSWORD=change-me

# ── Host wiring ─────────────────────────────────────────────────────────────
# The gid of the host's `docker` group — this is how the non-root Daffa container
# reads the root-owned socket. Find it with:  getent group docker | cut -d: -f3
DOCKER_GID=999

# The directory this compose file and .env live in, as an ABSOLUTE host path. Daffa mounts
# it read-only at /etc/daffa so `stack adopt` and `stack config` can read the compose,
# .env and traefik.yml. Absolute so a redeploy through Daffa's runner resolves the same
# path. Match your install location. (Traefik itself reads traefik.yml from a managed
# volume, not from here — the installer seeds it.)
DAFFA_CONFIG_DIR=/opt/daffa

# ── Protected resources ─────────────────────────────────────────────────────
# Networks and volumes this stack depends on. Daffa marks them `system` and refuses to
# remove them from the console — deleting the console's own plumbing is not a click we
# allow. Comma-separated. daffa-edge-certs / traefik-acme / daffa-edge-overlay only exist
# under Traefik.
DAFFA_SYSTEM_NETWORKS=daffa-internal,daffa-edge,daffa-edge-overlay
DAFFA_SYSTEM_VOLUMES=daffa-data,daffa-pg,daffa-edge-certs,traefik-acme

# ── Edge overlay driver ───────────────────────────────────────────────────────
# The network Traefik uses to reach PUBLISHED STACKS. `overlay` on a Swarm manager (the
# default install) so a replicated service is reachable on whatever node runs it; `bridge`
# on a --no-swarm / standalone box. The installer sets this to match; overlay needs Swarm.
DAFFA_EDGE_OVERLAY_DRIVER=overlay

# ── Image ───────────────────────────────────────────────────────────────────
# Pin to a released tag in production instead of :latest.
DAFFA_IMAGE=ghcr.io/mnshahawy/daffa:latest
